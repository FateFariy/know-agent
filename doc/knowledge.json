                    "properties": {
                      "confidence": {
                        "description": "置信度",
                        "type": "number"
                      },
                      "conversationId": {
                        "description": "会话ID",
                        "type": "string"
                      },
                      "createTime": {
                        "description": "创建时间",
                        "type": "string"
                      },
                      "errorMsg": {
                        "description": "错误信息",
                        "type": "string"
                      },
                      "exchangeId": {
                        "description": "轮次ID",
                        "type": "string"
                      },
                      "hitSelectedDocument": {
                        "description": "是否命中选中文档",
                        "type": "integer"
                      },
                      "id": {
                        "description": "主键ID",
                        "type": "string"
                      },
                      "mode": {
                        "description": "模式",
                        "type": "string"
                      },
                      "question": {
                        "description": "用户提问",
                        "type": "string"
                      },
                      "rewriteQuestion": {
                        "description": "改写后的问题",
                        "type": "string"
                      },
                      "routeStatus": {
                        "description": "路由状态",
                        "type": "string"
                      },
                      "selectedDocumentId": {
                        "description": "选中的文档ID",
                        "type": "string"
                      },
                      "topDocumentsJson": {
                        "description": "候选文档JSON",
                        "type": "string"
                      },
                      "topScopesJson": {
                        "description": "候选范围JSON",
                        "type": "string"
                      },
                      "topTopicsJson": {
                        "description": "候选主题JSON",
                        "type": "string"
                      }
                    }
                  }
                },
                "totalPages": {
                  "description": "总页数",
                  "type": "integer"
                },
                "totalSize": {
                  "description": "总条数",
                  "type": "integer"
                }
